{
  "crons": [
    { "path": "/api/swing/process", "schedule": "* * * * *" }
  ],
  "redirects": [
    {
      "source": "/((?!liff($|/)|api/auth/).*)",
      "has": [{ "type": "host", "value": "golf-buddy-prototype.vercel.app" }],
      "destination": "https://app.goltomo.com/$1",
      "permanent": false
    }
  ]
}
